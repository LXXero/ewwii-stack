#!/bin/sh
# Atomically refresh all taskbar focus/minimize classes from wlr-taskd.

list=$("$HOME/.local/bin/wlr-task" list 2>/dev/null)
if [ -z "$list" ]; then
  list=$(cat /tmp/ewwii_wlrctl.list 2>/dev/null)
fi

mappings=
i=1
while [ "$i" -le 32 ]; do
  state=$(printf '%s\n' "$list" | sed -n "${i}p" | cut -f4)
  case "$state" in
    F) klass="tb-item tb-focused" ;;
    M) klass="tb-item tb-minimized" ;;
    *) klass="tb-item" ;;
  esac

  entry="win_${i}_focused=\"$klass\""
  if [ -n "$mappings" ]; then
    mappings="$mappings,$entry"
  else
    mappings="$entry"
  fi
  i=$((i + 1))
done

ewwii update "$mappings" >/dev/null 2>&1 || true
echo ok
