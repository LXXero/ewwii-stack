#!/bin/sh
# mail_status — emits "<new>/<total>" for the mail widget, or empty string if
# this host has no maildir (widget hides). Used by ewwii.rhai.
DIR="${MAIL_DIR:-$HOME/.maildir}"
[ -d "$DIR/new" ] || { echo ""; exit 0; }
new=$(find "$DIR/new" -maxdepth 1 -type f 2>/dev/null | wc -l)
cur=$(find "$DIR/cur" -maxdepth 1 -type f 2>/dev/null | wc -l)
echo "${new}/$((new + cur))"
